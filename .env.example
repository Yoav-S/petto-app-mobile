EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_API_BASE_URL=
# When testing on a physical device with Expo Go, use your computer's LAN IP
# (e.g. http://192.168.1.10:8080) — localhost only works on emulator/simulator.

# Google Sign-In (Firebase Authentication → Sign-in method → Google → Web client ID)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# Required for Google on native (EAS development build or production — not Expo Go)
# Firebase Console → Project settings → Your apps → Android/iOS → OAuth client IDs
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# Google Cloud setup checklist (project petto-494013):
# 1. Firebase → Authentication → Sign-in method → Google → Enable
# 2. Google Cloud → Auth platform → Audience → add Test users (while Testing)
# 3. Android OAuth client: package com.yoavshamir.petto + SHA-1 from EAS build
# 4. iOS OAuth client: bundle ID com.yoavshamir.petto
# 5. Build dev client: eas build --profile development --platform android

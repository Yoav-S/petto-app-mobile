EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_API_BASE_URL=
# Production / phone testing against Cloud Run:
# https://petto-server-326582782489.europe-west1.run.app
# Local server on emulator: http://localhost:8080
# Local server on physical device: http://YOUR_LAN_IP:8080

# Google Sign-In (Firebase Authentication → Sign-in method → Google → Web client ID)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# Required for Google on native (EAS development build or production — not Expo Go)
# Firebase Console → Project settings → Your apps → Android/iOS → OAuth client IDs
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# Google Cloud setup checklist (project petto-494013):
# 1. Firebase → Authentication → Sign-in method → Google → Enable
# 2. Google Cloud → Auth platform → Audience → add Test users (while Testing)
# 3. Android OAuth client: package com.yoav.petto + SHA-1 from EAS build
# 4. iOS OAuth client: bundle ID com.yoav.petto
# 5. Build dev client: eas build --profile development --platform android

# RevenueCat (subscriptions) — public SDK keys from RevenueCat → Project → API keys
# IAP does NOT work in Expo Go; use an EAS development / production build.
EXPO_PUBLIC_REVENUECAT_IOS_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=
# Product / entitlement IDs (must match RevenueCat):
#   entitlement: petto_premium
#   product:     sub_premium
#   offering:    default → Monthly → sub_premium
# Server webhook: POST /api/v1/subscriptions/webhook  (Bearer = REVENUECAT_WEBHOOK_SECRET)
